{
  "name": "client-ready-playwright-framework",
  "version": "1.0.0",
  "description": "Client-ready Playwright TypeScript automation framework with fixtures, environment support, reporting, and KT documentation.",
  "private": true,
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:ci": "playwright test",
    "test:headed": "playwright test --headed",
    "test:list": "playwright test --list",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "framework",
    "e2e"
  ],
  "author": "Shyamjeet",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^24.4.0",
    "@playwright/test": "^1.57.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
