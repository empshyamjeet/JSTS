{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "outDir": "dist",
    "sourceMap": true
  },
  "include": [
    ".github/**/*.ts",
    "config/**/*.ts",
    "docs/**/*.ts",
    "fixtures/**/*.ts",
    "playwright.config.ts",
    "pages/**/*.ts",
    "test-data/**/*.ts",
    "tests/**/*.ts",
    "utils/**/*.ts"
  ],
  "exclude": ["dist", "node_modules", "reports", "test-results"]
}
